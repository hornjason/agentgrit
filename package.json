{
  "name": "@agentgrit/core",
  "version": "0.1.4",
  "type": "module",
  "description": "Self-learning engine that makes AI agents smarter over time",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./graph": {
      "import": "./src/graph/index.ts",
      "types": "./src/graph/index.ts"
    },
    "./capture": {
      "import": "./src/capture/index.ts",
      "types": "./src/capture/index.ts"
    }
  },
  "bin": {
    "agentgrit": "dist/agentgrit.js"
  },
  "files": [
    "dist/",
    "rubrics/",
    "agentgrit.config.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "bun test",
    "build": "bun build bin/agentgrit.ts --outfile dist/agentgrit.js --target=node --minify",
    "prepublishOnly": "bun run build",
    "lint": "bunx biome check .",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hornjason/agentgrit.git"
  },
  "keywords": [
    "claude-code",
    "ai-agents",
    "self-learning",
    "feedback-loop"
  ]
}
